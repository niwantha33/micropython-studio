{
  "name": "micropython-studio",
  "displayName": "MicroPython Studio",
  "description": "MicroPython Studio for VS Code — write, deploy, and debug - MicroPython, CircuitPython, and XBee on real hardware",
  "version": "1.1.1",
  "publisher": "niwantha33",
  "license": "MIT",
  "author": {
    "name": "Niwantha Meepage",
    "email": "niwantha33@gmail.com"
  },
  "bugs": {
    "url": "https://github.com/niwantha33/micropython-studio/issues",
    "email": "niwantha33@gmail.com"
  },
  "homepage": "https://github.com/niwantha33/micropython-studio#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/niwantha33/micropython-studio.git"
  },
  "keywords": [
    "micropython",
    "micropython debug",    
    "circuitpython",
    "micropython studio",
    "circuitpython studio",
    "xbee",
    "raspberry",
    "raspberry pi pico",
    "esp32",
    "iot",
    "embedded",
    "mpremote",
    "microcontroller"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "icon": "resource/micropython_studio_icon_128.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "micropython-ide-launch",
          "title": "MicroPython Studio",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "views": {
      "micropython-ide-launch": [
        {
          "id": "micropython-ide-launch-view",
          "name": "MicroPython Studio",
          "icon": "$(circuit-board)"
        },
        {
          "id": "micropython-ide-ai-chat",
          "type": "webview",
          "name": "Private AI Assistance",
          "icon": "$(hubot)"
        }
      ],
      "explorer": [
        {
          "id": "micropython-ide-device-files",
          "name": "Device Files (MicroPython)",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "micropython-ide-launch-view",
        "contents": "Welcome to MicroPython Studio! 🚀\n\nGet started by setting up your environment and creating a project.\n\n[$(gear) Setup Environment](command:micropython-ide.setupEnvironment)\n[$(file-add) Create New Project](command:micropython-ide.createNewProject)\n[$(folder-opened) Open Existing Project](command:micropython-ide.openExistingProjectFolder)\n\n──────────────────────────\n\n[$(dashboard) Open Device Dashboard](command:micropython-ide.openDeviceDashboard)\n[$(refresh) Refresh Device Files](command:micropython-ide.refreshMcuFolder)\n[$(plug) Update Device Port](command:micropython-ide.updateDevicePort)\n[$(package) Install Package](command:micropython-ide.installPackage)\n[$(cloud-upload) Upload File to Device](command:micropython-ide.uploadFileToDevice)\n[$(cloud-upload) Upload Project to Device](command:micropython-ide.uploadProjectToDevice)\n\n──────────────────────────\n\n[$(flame) Flash Firmware to Device](command:micropython-ide.flashFirmware)\n[$(cloud-download) Download Firmware](command:micropython-ide.downloadFirmware)\n\n──────────────────────────\n\n[$(hubot) Enter Private AI Assistance](command:micropython-ide.enterAiAssistance)\n\n──────────────────────────\n\n[$(bug) Start Debug](command:micropython-ide.startDebug)\n[$(cloud-download) Flash Debug Firmware](command:micropython-ide.flashDebugFirmware)",
        "when": "true"
      }
    ],
    "commands": [
      {
        "command": "micropython-ide.setupEnvironment",
        "title": "MicroPython: Setup Development Environment",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.createNewProject",
        "title": "MicroPython: Create New Project",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.openExistingProjectFolder",
        "title": "MicroPython: Open Existing Project",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.refreshMcuFolder",
        "title": "MicroPython: Refresh Device Files",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.enterAiAssistance",
        "title": "MicroPython: Enter Private AI Assistance",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.openShell",
        "title": "MicroPython: Open Device Shell",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.mountMainFolder",
        "title": "MicroPython: Mount & Run on Device",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.stopRun",
        "title": "MicroPython: Stop Running Script",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.runThisScriptOnMcuConsole",
        "title": "MicroPython: Run Script on Device",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.chooseRunTarget",
        "title": "MicroPython: Choose Run Target",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.startDebug",
        "title": "MicroPython: Start Debug Session",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.flashDebugFirmware",
        "title": "MicroPython: Flash Debug Firmware (download + write)",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.updateDevicePort",
        "title": "MicroPython: Update Device Port",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.refreshDeviceFiles",
        "title": "MicroPython: Refresh Device Files Tree",
        "category": "MicroPython Studio",
        "icon": "$(refresh)"
      },
      {
        "command": "micropython-ide.readDeviceFile",
        "title": "MicroPython: Read File from Device",
        "category": "MicroPython Studio"
      },
      {
        "command": "micropython-ide.deleteDeviceFile",
        "title": "MicroPython: Delete File from Device",
        "category": "MicroPython Studio",
        "icon": "$(trash)"
      },
      {
        "command": "micropython-ide.deleteDeviceFolder",
        "title": "MicroPython: Delete Folder from Device",
        "category": "MicroPython Studio",
        "icon": "$(trash)"
      },
      {
        "command": "micropython-ide.uploadFileToDevice",
        "title": "MicroPython: Upload Current File to Device",
        "category": "MicroPython Studio",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "micropython-ide.uploadFolderToDevice",
        "title": "MicroPython: Upload Folder to Device",
        "category": "MicroPython Studio",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "micropython-ide.uploadProjectToDevice",
        "title": "MicroPython: Upload Project to Device",
        "category": "MicroPython Studio",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "micropython-ide.compileToBytecode",
        "title": "MicroPython: Compile to Bytecode (.mpy)",
        "category": "MicroPython Studio",
        "icon": "$(zap)"
      },
      {
        "command": "micropython-ide.generateFlowchart",
        "title": "MicroPython: Generate Flowchart (code2flow)",
        "category": "MicroPython Studio",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "micropython-ide.installPackage",
        "title": "MicroPython: Install Package",
        "category": "MicroPython Studio",
        "icon": "$(package)"
      },
      {
        "command": "micropython-ide.flashFirmware",
        "title": "MicroPython: Flash Firmware to Device",
        "category": "MicroPython Studio",
        "icon": "$(flame)"
      },
      {
        "command": "micropython-ide.downloadFirmware",
        "title": "MicroPython: Download Firmware",
        "category": "MicroPython Studio",
        "icon": "$(cloud-download)"
      },
      {
        "command": "micropython-ide.openDeviceDashboard",
        "title": "MicroPython: Open Device Dashboard",
        "category": "MicroPython Studio",
        "icon": "$(dashboard)"
      },
      {
        "command": "micropython-ide.downloadFromDevice",
        "title": "MicroPython: Download Files from Device",
        "category": "MicroPython Studio",
        "icon": "$(cloud-download)"
      },
      {
        "command": "micropython-ide.renameDeviceFile",
        "title": "MicroPython: Rename",
        "category": "MicroPython Studio",
        "icon": "$(edit)"
      },
      {
        "command": "micropython-ide.uploadToDeviceFolder",
        "title": "MicroPython: Upload to This Folder",
        "category": "MicroPython Studio",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "micropython-ide.newDeviceFolder",
        "title": "MicroPython: New Folder",
        "category": "MicroPython Studio",
        "icon": "$(new-folder)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "micropython-ide.setupEnvironment",
          "when": "true"
        },
        {
          "command": "micropython-ide.createNewProject",
          "when": "true"
        },
        {
          "command": "micropython-ide.openExistingProjectFolder",
          "when": "true"
        },
        {
          "command": "micropython-ide.refreshMcuFolder",
          "when": "true"
        },
        {
          "command": "micropython-ide.openShell",
          "when": "true"
        },
        {
          "command": "micropython-ide.mountMainFolder",
          "when": "true"
        },
        {
          "command": "micropython-ide.stopRun",
          "when": "true"
        },
        {
          "command": "micropython-ide.startDebug",
          "when": "true"
        },
        {
          "command": "micropython-ide.updateDevicePort",
          "when": "true"
        },
        {
          "command": "micropython-ide.uploadFileToDevice",
          "when": "true"
        },
        {
          "command": "micropython-ide.uploadProjectToDevice",
          "when": "true"
        },
        {
          "command": "micropython-ide.compileToBytecode",
          "when": "true"
        },
        {
          "command": "micropython-ide.generateFlowchart",
          "when": "true"
        },
        {
          "command": "micropython-ide.installPackage",
          "when": "true"
        },
        {
          "command": "micropython-ide.flashFirmware",
          "when": "true"
        },
        {
          "command": "micropython-ide.downloadFirmware",
          "when": "true"
        },
        {
          "command": "micropython-ide.openDeviceDashboard",
          "when": "true"
        }
      ],
      "explorer/context": [
        {
          "command": "micropython-ide.refreshMcuFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "micropython-ide.uploadFileToDevice",
          "when": "resourceExtname == .py || resourceExtname == .mpy",
          "group": "micropython@1"
        },
        {
          "command": "micropython-ide.uploadFolderToDevice",
          "when": "explorerResourceIsFolder",
          "group": "micropython@1"
        },
        {
          "command": "micropython-ide.runThisScriptOnMcuConsole",
          "when": "(resourceExtname == .py || resourceExtname == .mpy) && micropythonStudio.isCircuitPython",
          "group": "micropython@2"
        },
        {
          "command": "micropython-ide.compileToBytecode",
          "when": "resourceExtname == .py",
          "group": "micropython@3"
        },
        {
          "command": "micropython-ide.generateFlowchart",
          "when": "resourceExtname == .py",
          "group": "micropython@4"
        }
      ],
      "view/title": [
        {
          "command": "micropython-ide.refreshDeviceFiles",
          "when": "view == micropython-ide-device-files",
          "group": "navigation"
        },
        {
          "command": "micropython-ide.uploadFileToDevice",
          "when": "view == micropython-ide-device-files",
          "group": "navigation"
        },
        {
          "command": "micropython-ide.uploadProjectToDevice",
          "when": "view == micropython-ide-device-files",
          "group": "navigation"
        },
        {
          "command": "micropython-ide.installPackage",
          "when": "view == micropython-ide-device-files",
          "group": "navigation"
        },
        {
          "command": "micropython-ide.downloadFromDevice",
          "when": "view == micropython-ide-device-files",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "micropython-ide.deleteDeviceFile",
          "when": "view == micropython-ide-device-files && viewItem == deviceFile",
          "group": "inline"
        },
        {
          "command": "micropython-ide.deleteDeviceFile",
          "when": "view == micropython-ide-device-files && viewItem == deviceFile",
          "group": "context"
        },
        {
          "command": "micropython-ide.deleteDeviceFolder",
          "when": "view == micropython-ide-device-files && viewItem == deviceFolder",
          "group": "inline"
        },
        {
          "command": "micropython-ide.deleteDeviceFolder",
          "when": "view == micropython-ide-device-files && viewItem == deviceFolder",
          "group": "context"
        },
        {
          "command": "micropython-ide.renameDeviceFile",
          "when": "view == micropython-ide-device-files && (viewItem == deviceFile || viewItem == deviceFolder)",
          "group": "micropython@1"
        },
        {
          "command": "micropython-ide.uploadToDeviceFolder",
          "when": "view == micropython-ide-device-files && viewItem == deviceFolder",
          "group": "micropython@2"
        },
        {
          "command": "micropython-ide.newDeviceFolder",
          "when": "view == micropython-ide-device-files && viewItem == deviceFolder",
          "group": "micropython@3"
        }
      ]
    }
  },
  "configuration": {
    "title": "MicroPython Studio",
    "properties": {
      "micropythonStudio.circuitpython.autoSyncAfterInstall": {
        "type": "boolean",
        "default": false,
        "description": "CircuitPython: Automatically sync files from the CIRCUITPY drive to the local main/ folder after installing a package with circup."
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.x",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.3.9",
    "eslint": "^8.57.0",
    "glob": "^10.3.10",
    "mocha": "^7.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "jsdom": "^29.0.2",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^1.1.1"
  }
}